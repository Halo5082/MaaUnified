{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "MAAUnified.AcceptanceTemplate.v1",
  "title": "MAAUnified Acceptance Template v1",
  "type": "object",
  "required": [
    "schema_version",
    "baseline_ref",
    "matrix",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "baseline_ref": {
      "type": "string"
    },
    "matrix": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "waiver": {
            "$ref": "#/$defs/waiver"
          },
          "waiver_scope": {
            "$ref": "#/$defs/waiver_scope"
          }
        }
      }
    }
  },
  "$defs": {
    "waiver": {
      "type": "object",
      "required": [
        "owner",
        "reason",
        "expires_on",
        "alternative_validation"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "expires_on": {
          "type": "string"
        },
        "alternative_validation": {
          "type": "string"
        }
      }
    },
    "waiver_scope": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "themes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "locales": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
