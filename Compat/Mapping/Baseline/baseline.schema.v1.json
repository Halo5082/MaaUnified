{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "MAAUnified.BaselineFreeze.v1",
  "title": "MAAUnified Baseline Freeze v1",
  "type": "object",
  "required": [
    "schema_version",
    "frozen_at_utc",
    "wpf_baseline_commit",
    "themes",
    "locales",
    "items",
    "config_key_mappings",
    "fallback_capabilities"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "frozen_at_utc": {
      "type": "string"
    },
    "wpf_baseline_commit": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "waiver": {
            "$ref": "#/$defs/waiver"
          },
          "waiver_scope": {
            "$ref": "#/$defs/waiver_scope"
          }
        }
      }
    },
    "config_key_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "waiver": {
            "$ref": "#/$defs/waiver"
          }
        }
      }
    },
    "fallback_capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "waiver": {
            "$ref": "#/$defs/waiver"
          },
          "waiver_scope": {
            "$ref": "#/$defs/waiver_scope"
          }
        }
      }
    }
  },
  "$defs": {
    "waiver": {
      "type": "object",
      "required": [
        "owner",
        "reason",
        "expires_on",
        "alternative_validation"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "expires_on": {
          "type": "string"
        },
        "alternative_validation": {
          "type": "string"
        }
      }
    },
    "waiver_scope": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "themes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "locales": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
