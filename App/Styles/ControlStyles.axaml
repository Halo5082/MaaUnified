<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Thickness x:Key="MAA.BorderThickness.Thin">1</Thickness>

    <CornerRadius x:Key="MAA.CornerRadius.Item">4</CornerRadius>
    <CornerRadius x:Key="MAA.CornerRadius.Section">8</CornerRadius>
    <CornerRadius x:Key="MAA.CornerRadius.SectionStrong">10</CornerRadius>
    <CornerRadius x:Key="MAA.CornerRadius.Action">6</CornerRadius>

    <Thickness x:Key="MAA.Thickness.CopilotRootMargin">4</Thickness>
    <Thickness x:Key="MAA.Thickness.PageMargin">12</Thickness>
    <Thickness x:Key="MAA.Thickness.SectionPadding">8</Thickness>
    <Thickness x:Key="MAA.Thickness.SectionPaddingStrong">10</Thickness>
    <Thickness x:Key="MAA.Thickness.SectionTitleMargin">0,0,0,4</Thickness>
    <Thickness x:Key="MAA.Thickness.MainWindowHeaderInfoMargin">0,0,12,0</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginTopSection">0,10,0,0</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginSectionVertical">0,10,0,10</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginRightSection">0,0,10,0</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginTopList">0,6,0,0</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginLeftSmall">6,0,0,0</Thickness>
    <Thickness x:Key="MAA.Thickness.ItemPadding">6</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginItemVertical">0,2,0,2</Thickness>
    <Thickness x:Key="MAA.Thickness.MarginActionButtonLeft">8,0,0,0</Thickness>
    <Thickness x:Key="MAA.Thickness.TaskQueue.ValidationSummaryMargin">0,8,0,8</Thickness>
    <Thickness x:Key="MAA.Thickness.ActionPadding">12,0</Thickness>

    <x:Double x:Key="MAA.Spacing.Tight">2</x:Double>
    <x:Double x:Key="MAA.Spacing.Small">6</x:Double>
    <x:Double x:Key="MAA.Spacing.Medium">8</x:Double>
    <x:Double x:Key="MAA.Spacing.Large">10</x:Double>

    <x:Double x:Key="MAA.FontSize.SectionTitle">14</x:Double>
    <x:Double x:Key="MAA.FontSize.WindowTitle">20</x:Double>

    <x:Double x:Key="MAA.Size.MainWindow.Width">1400</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.Height">920</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.MinWidth">1200</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.MinHeight">760</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.PinToggleWidth">48</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.PinToggleHeight">32</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.ConfigIssueMaxHeight">120</x:Double>
    <x:Double x:Key="MAA.Size.MainWindow.RootLogsMaxHeight">140</x:Double>

    <x:Double x:Key="MAA.Size.Action.MinWidth">88</x:Double>
    <x:Double x:Key="MAA.Size.Action.Height">32</x:Double>
    <x:Double x:Key="MAA.Size.TaskQueue.RenameTextWidth">220</x:Double>
    <x:Double x:Key="MAA.Size.TaskQueue.OverlayTargetWidth">240</x:Double>

    <ColumnDefinitions x:Key="MAA.Layout.MainWindow.ConnectionColumns">Auto,220,180,220,*,Auto,Auto</ColumnDefinitions>
    <ColumnDefinitions x:Key="MAA.Layout.MainWindow.ContentColumns">*,280</ColumnDefinitions>
    <ColumnDefinitions x:Key="MAA.Layout.TaskQueue.Columns">280,*,320</ColumnDefinitions>
    <ColumnDefinitions x:Key="MAA.Layout.Settings.Columns">220,*</ColumnDefinitions>
    <ColumnDefinitions x:Key="MAA.Layout.Copilot.Columns">2*,3,2*</ColumnDefinitions>
    <ColumnDefinitions x:Key="MAA.Layout.Toolbox.Columns">2*,3,3*</ColumnDefinitions>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Window}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.section">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Section}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.SectionPadding}" />
  </Style>

  <Style Selector="Border.section.section-strong">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.SectionStrong}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.SectionStrong}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.SectionPaddingStrong}" />
  </Style>

  <Style Selector="Border.section.section-warning">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Warning}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Warning}" />
  </Style>

  <Style Selector="Border.item-card">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Item}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ItemPadding}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.MarginItemVertical}" />
  </Style>

  <Style Selector="Border.item-card.status-running">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Running}" />
  </Style>

  <Style Selector="Border.item-card.status-success">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Success}" />
  </Style>

  <Style Selector="Border.item-card.status-error">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Error}" />
  </Style>

  <Style Selector="Border.item-card.status-skipped">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Skipped}" />
  </Style>

  <Style Selector="Border.item-card.status-idle">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Idle}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.SectionTitleMargin}" />
  </Style>

  <Style Selector="TextBlock.long-wrap">
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.long-ellipsis">
    <Setter Property="TextWrapping" Value="NoWrap" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.state-warning">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Warning}" />
  </Style>

  <Style Selector="TextBlock.state-error">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Error}" />
  </Style>

  <Style Selector="TextBlock.state-success">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Success}" />
  </Style>

  <Style Selector="Button.action">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Action.MinWidth}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.Action.Height}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ActionPadding}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Action}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.Background}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Action.Border}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.Foreground}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.action:pointerover">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.BackgroundHover}" />
  </Style>

  <Style Selector="Button.action:pressed">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.BackgroundPressed}" />
  </Style>

  <Style Selector="Button.action:disabled">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.BackgroundDisabled}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.ForegroundDisabled}" />
  </Style>
</Styles>
