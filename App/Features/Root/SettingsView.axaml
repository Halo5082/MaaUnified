<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settingsViews="clr-namespace:MAAUnified.App.Features.Settings"
             x:Class="MAAUnified.App.Features.Root.SettingsView">
  <Grid ColumnDefinitions="{StaticResource MAA.Layout.Settings.Columns}">
    <Border Grid.Column="0" Classes="wpf-panel">
      <ListBox ItemsSource="{Binding Sections}"
               SelectedItem="{Binding SelectedSection}"
               SelectionChanged="OnSectionSelectionChanged">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Classes="long-ellipsis" Text="{Binding DisplayName}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <Border Grid.Column="1" Classes="wpf-panel">
      <ScrollViewer x:Name="SectionScrollViewer"
                    ScrollChanged="OnSectionScrollChanged">
        <StackPanel x:Name="SectionContentPanel"
                    Spacing="{DynamicResource MAA.Spacing.Large}">
          <Border x:Name="SectionConfigurationManager" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:ConfigurationManagerView />
          </Border>

          <Border x:Name="SectionTimer" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:TimerSettingsView />
          </Border>

          <Border x:Name="SectionPerformance" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:PerformanceSettingsView />
          </Border>

          <Border x:Name="SectionGame" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:GameSettingsView />
          </Border>

          <Border x:Name="SectionConnect" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:ConnectSettingsView DataContext="{Binding ConnectionGameSharedState}" />
          </Border>

          <Border x:Name="SectionStart" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:StartSettingsView />
          </Border>

          <Border x:Name="SectionRemoteControl" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:RemoteControlSettingsView />
          </Border>

          <Border x:Name="SectionGui" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:GuiSettingsView />
          </Border>

          <Border x:Name="SectionBackground" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:BackgroundSettingsView />
          </Border>

          <Border x:Name="SectionExternalNotification" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:ExternalNotificationSettingsView />
          </Border>

          <Border x:Name="SectionHotKey" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:HotKeySettingsView />
          </Border>

          <Border x:Name="SectionAchievement" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:AchievementSettingsView />
          </Border>

          <Border x:Name="SectionVersionUpdate" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:VersionUpdateSettingsView />
          </Border>

          <Border x:Name="SectionIssueReport" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:IssueReportView />
          </Border>

          <Border x:Name="SectionAbout" Classes="wpf-panel wpf-panel-strong">
            <settingsViews:AboutSettingsView />
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
