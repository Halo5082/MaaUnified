<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.TrayIntegrationView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <TextBlock Classes="section-title" Text="{Binding Texts[Toolbox.Advanced.Tray.Title]}" />
    <TextBlock Grid.Row="1" Classes="long-wrap" Text="{Binding CapabilitySummary}" />
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*">
      <CheckBox Content="{Binding Texts[Toolbox.Advanced.Tray.Visible]}" IsChecked="{Binding TrayVisible}" />
      <Button Grid.Column="1"
              Classes="wpf-button"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              Content="{Binding Texts[Toolbox.Advanced.Tray.ApplyVisibility]}"
              Click="OnApplyTrayVisibilityClick" />
      <Button Grid.Column="2"
              Classes="wpf-button"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              Content="{Binding Texts[Toolbox.Advanced.Tray.SyncMenuState]}"
              Click="OnSyncMenuStateClick" />
      <Button Grid.Column="3"
              Classes="wpf-button"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              HorizontalAlignment="Left"
              Content="{Binding Texts[Toolbox.Advanced.Tray.RefreshCapability]}"
              Click="OnRefreshCapabilityClick" />
    </Grid>
    <Grid Grid.Row="3" ColumnDefinitions="Auto,200,Auto,*">
      <TextBlock VerticalAlignment="Center" Text="{Binding Texts[Toolbox.Advanced.Tray.MessageTitle]}" />
      <TextBox Text="{Binding TrayMessageTitle}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Texts[Toolbox.Advanced.Tray.MessageBody]}" />
      <TextBox Grid.Column="3" Text="{Binding TrayMessageBody}" />
    </Grid>
    <StackPanel Grid.Row="4" Spacing="{DynamicResource MAA.Spacing.Small}">
      <Button Classes="wpf-button" Content="{Binding Texts[Toolbox.Advanced.Tray.SendMessage]}" Click="OnSendTrayMessageClick" />
      <TextBlock Text="{Binding StatusMessage}" />
      <TextBlock Classes="state-error long-wrap" Text="{Binding LastErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
