<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.TrayIntegrationView">
  <Border Padding="12" BorderThickness="1" BorderBrush="#3A4A55" CornerRadius="8" Margin="4">
    <StackPanel Spacing="6">
      <TextBlock FontSize="18" FontWeight="Bold" Text="TrayIntegration" />
      <TextBlock Text="MAAUnified Advanced 模块：TrayIntegration" TextWrapping="Wrap" />
      <TextBlock Opacity="0.75" Text="已接入同构布局入口与能力状态。" TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</UserControl>
