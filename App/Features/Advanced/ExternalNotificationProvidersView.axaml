<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.ExternalNotificationProvidersView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <TextBlock Classes="section-title" Text="External Notification Providers" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,200,Auto,*">
      <TextBlock VerticalAlignment="Center" Text="Provider" />
      <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="参数(JSON)" />
      <TextBox Grid.Column="3" Text="{Binding ParametersText}" Watermark="key=value;key2=value2" />
    </Grid>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,200,Auto,*">
      <TextBlock VerticalAlignment="Center" Text="标题" />
      <TextBox Text="{Binding Title}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="内容" />
      <TextBox Grid.Column="3" Text="{Binding Message}" />
    </Grid>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="{DynamicResource MAA.Spacing.Small}">
      <Button Classes="wpf-button" Content="刷新 Provider" Click="OnRefreshProvidersClick" />
      <Button Classes="wpf-button" Content="校验参数" Click="OnValidateClick" />
      <Button Classes="wpf-button" Content="发送测试" Click="OnSendTestClick" />
    </StackPanel>
    <StackPanel Grid.Row="4" Spacing="{DynamicResource MAA.Spacing.Small}">
      <TextBlock Text="{Binding StatusMessage}" />
      <TextBlock Classes="state-error long-wrap" Text="{Binding LastErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
