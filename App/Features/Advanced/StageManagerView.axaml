<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.StageManagerView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <TextBlock Classes="section-title" Text="Stage Manager" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
      <TextBlock VerticalAlignment="Top" Text="关卡列表" />
      <TextBox Text="{Binding StageCodesText}"
               AcceptsReturn="True"
               Height="120"
               Watermark="一行一个或用逗号分隔，例如 1-7, CE-5"
               TextWrapping="Wrap" />
    </Grid>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*">
      <CheckBox Content="自动轮转" IsChecked="{Binding AutoIterate}" />
      <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="上次关卡" />
      <TextBox Grid.Column="2" Text="{Binding LastSelectedStage}" Width="180" />
      <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="{DynamicResource MAA.Spacing.Small}">
        <Button Classes="wpf-button" Content="校验" Click="OnValidateClick" />
        <Button Classes="wpf-button" Content="保存" Click="OnSaveClick" />
      </StackPanel>
    </Grid>
    <TextBlock Grid.Row="3" Classes="long-wrap" Text="{Binding StatusMessage}" />
    <TextBlock Grid.Row="4" Classes="state-error long-wrap" Text="{Binding LastErrorMessage}" />
  </Grid>
</UserControl>
