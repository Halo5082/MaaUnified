<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:taskVm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.Advanced.CopilotView">
  <UserControl.Styles>
    <Style Selector="Button.wpf-button.copilot-icon">
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="8,0" />
    </Style>
    <Style Selector="Button.wpf-button.copilot-list-action">
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="10,0" />
    </Style>
    <Style Selector="Button.wpf-button.overlay-toggle">
      <Setter Property="MinWidth" Value="112" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="12,0" />
    </Style>
    <Style Selector="Border.overlay-indicator">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-preview">
      <Setter Property="Background" Value="#D9A441" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-native">
      <Setter Property="Background" Value="#4FA86C" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-hidden">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
    </Style>
  </UserControl.Styles>
  <UserControl.DataTemplates>
    <DataTemplate DataType="taskVm:TaskQueueLogEntryViewModel">
      <Border Classes="wpf-card">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Classes="subtle"
                     VerticalAlignment="Top"
                     IsVisible="{Binding HasTime}"
                     Text="{Binding Time}" />
          <TextBlock Grid.Column="1"
                     Classes="long-wrap"
                     Classes.state-error="{Binding IsError}"
                     Classes.state-warning="{Binding IsWarning}"
                     Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                     Text="{Binding Content}" />
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid ColumnDefinitions="*,Auto,420"
        Margin="{DynamicResource MAA.Thickness.CopilotRootMargin}">
    <Border Grid.Column="0" Classes="wpf-panel">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Spacing="{DynamicResource MAA.Spacing.Small}">
          <TabControl SelectedIndex="{Binding CopilotTabIndex}"
                      IsEnabled="{Binding CanEdit}">
            <TabItem Header="{Binding Texts[Copilot.Tab.Main]}" />
            <TabItem Header="{Binding Texts[Copilot.Tab.Security]}" />
            <TabItem Header="{Binding Texts[Copilot.Tab.Paradox]}" />
            <TabItem Header="{Binding Texts[Copilot.Tab.Other]}" />
          </TabControl>

          <Grid ColumnDefinitions="*,Auto,Auto,Auto">
            <Grid Grid.Column="0">
              <controls:CheckComboBox Text="{Binding DisplayFilename}"
                                      Watermark="{Binding Texts[Copilot.Input.PathOrCodeWatermark]}"
                                      IsEditable="True"
                                      IsEnabled="{Binding CanEdit}"
                                      IsTreeMode="True"
                                      ItemsSource="{Binding FileItems}"
                                      IsDropDownOpen="{Binding IsFilePopupOpen}"
                                      EditorCommitted="OnFileSelectorEditorCommitted"
                                      SelectionCommitted="OnFileSelectorSelectionCommitted" />
            </Grid>

            <Button Grid.Column="1"
                    Classes="wpf-button wpf-button-secondary copilot-icon"
                    Margin="6,0,0,0"
                    Content="{Binding Texts[Copilot.Button.File]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.File]}"
                    Click="OnSelectFileClick"
                    IsEnabled="{Binding CanEdit}" />
            <Button Grid.Column="2"
                    Classes="wpf-button wpf-button-secondary copilot-icon"
                    Margin="6,0,0,0"
                    Content="{Binding Texts[Copilot.Button.Paste]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.Paste]}"
                    Click="OnPasteClipboardClick"
                    IsEnabled="{Binding CanEdit}" />
            <Button Grid.Column="3"
                    Classes="wpf-button wpf-button-secondary copilot-icon"
                    Margin="6,0,0,0"
                    Content="{Binding Texts[Copilot.Button.PasteSet]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.PasteSet]}"
                    Click="OnPasteClipboardSetClick"
                    IsVisible="{Binding ShowClipboardSetButton}"
                    IsEnabled="{Binding CanEdit}" />
          </Grid>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
          <Grid Margin="0,10,0,0"
                RowDefinitions="Auto,*">
            <Grid Grid.Row="0"
                  HorizontalAlignment="Center">
              <Button Width="120"
                      Height="48"
                      Classes="wpf-button wpf-button-primary"
                      Content="{Binding Texts[Copilot.Action.Start]}"
                      Click="OnStartClick"
                      IsVisible="{Binding CanEdit}"
                      IsEnabled="{Binding CanStart}" />
              <Button Width="120"
                      Height="48"
                      Classes="wpf-button wpf-button-secondary"
                      Content="{Binding Texts[Copilot.Action.Stop]}"
                      Click="OnStopClick"
                      IsVisible="{Binding CanStop}"
                      IsEnabled="{Binding CanStop}" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Spacing="{DynamicResource MAA.Spacing.Tight}"
                        IsEnabled="{Binding CanEdit}">
              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowFormationGroup}">
                <CheckBox Content="{Binding Texts[Copilot.Option.AutoSquad]}"
                          IsChecked="{Binding Form}" />
                <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                      Tip="{Binding Texts[Copilot.Tip.AutoSquad]}" />
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          Margin="24,0,0,0"
                          IsVisible="{Binding ShowUseFormation}">
                <CheckBox Content="{Binding Texts[Copilot.Option.UseFormation]}"
                          IsChecked="{Binding UseFormation}" />
                <ComboBox Width="100"
                          Margin="8,0,0,0"
                          IsVisible="{Binding UseFormation}"
                          ItemsSource="{Binding FormationOptions}"
                          SelectedItem="{Binding SelectedFormationOption}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowIgnoreRequirements}">
                <CheckBox Content="{Binding Texts[Copilot.Option.IgnoreRequirements]}"
                          IsChecked="{Binding IgnoreRequirements}" />
                <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                      Tip="{Binding Texts[Copilot.Tip.IgnoreRequirements]}" />
              </StackPanel>

              <StackPanel Spacing="{DynamicResource MAA.Spacing.Tight}"
                          IsVisible="{Binding ShowSupportUnitUsage}">
                <StackPanel Orientation="Horizontal">
                  <CheckBox Content="{Binding Texts[Copilot.Option.UseSupportUnit]}"
                            IsChecked="{Binding UseSupportUnitUsage}" />
                  <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                        Tip="{Binding Texts[Copilot.Tip.UseSupportUnit]}" />
                </StackPanel>
                <ComboBox Width="120"
                          Margin="24,0,0,0"
                          IsVisible="{Binding UseSupportUnitUsage}"
                          ItemsSource="{Binding SupportUnitUsageOptions}"
                          SelectedItem="{Binding SelectedSupportUnitUsageOption}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <CheckBox Content="{Binding Texts[Copilot.Option.AddTrust]}"
                        IsChecked="{Binding AddTrust}"
                        IsVisible="{Binding ShowAddTrust}" />

              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowAddUserAdditional}">
                <CheckBox Content="{Binding Texts[Copilot.Option.AddUserAdditional]}"
                          IsChecked="{Binding AddUserAdditional}" />
                <Button x:Name="UserAdditionalButton"
                        Classes="wpf-button wpf-button-secondary copilot-icon"
                        Margin="8,0,0,0"
                        Padding="8,0"
                        Content="{Binding Texts[Copilot.Button.Edit]}"
                        Click="OnOpenUserAdditionalPopupClick" />
                <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                      Tip="{Binding Texts[Copilot.Tip.UserAdditionalFormat]}" />
                <Popup IsOpen="{Binding IsUserAdditionalPopupOpen}"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=UserAdditionalButton}"
                       IsLightDismissEnabled="True">
                  <Border Width="520"
                          MaxHeight="420"
                          Padding="12"
                          Classes="wpf-panel">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBlock Text="{Binding Texts[Copilot.Popup.UserAdditionalTitle]}" />
                      <ScrollViewer Grid.Row="1"
                                    Margin="0,8,0,8"
                                    MaxHeight="320">
                        <ItemsControl ItemsSource="{Binding UserAdditionalItems}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="*,72,120,Auto"
                                    Margin="0,0,0,6">
                                <TextBox Text="{Binding Name}"
                                         Watermark="{Binding DataContext.Texts[Copilot.Input.OperatorNameWatermark], RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <controls:VerticalSpinNumberBox Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                Minimum="1"
                                                                Maximum="3"
                                                                Value="{Binding Skill}" />
                                <ComboBox Grid.Column="2"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding DataContext.ModuleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedIndex="{Binding Module}">
                                  <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                      <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                  </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="3"
                                        Classes="wpf-button wpf-button-secondary copilot-list-action"
                                        Margin="8,0,0,0"
                                        Content="{Binding DataContext.Texts[Copilot.Button.Delete], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Tag="{Binding}"
                                        Click="OnRemoveUserAdditionalItemClick" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                      <Grid Grid.Row="2"
                            ColumnDefinitions="*,Auto,Auto">
                        <Button Classes="wpf-button wpf-button-secondary"
                                Content="{Binding Texts[Copilot.Button.Add]}"
                                HorizontalAlignment="Left"
                                Click="OnAddUserAdditionalItemClick" />
                        <Button Grid.Column="1"
                                Classes="wpf-button"
                                Margin="8,0,0,0"
                                Content="{Binding Texts[Copilot.Button.Confirm]}"
                                Click="OnSaveUserAdditionalClick" />
                        <Button Grid.Column="2"
                                Classes="wpf-button wpf-button-secondary"
                                Margin="8,0,0,0"
                                Content="{Binding Texts[Copilot.Button.Cancel]}"
                                Click="OnCancelUserAdditionalClick" />
                      </Grid>
                    </Grid>
                  </Border>
                </Popup>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowUseCopilotList}">
                <CheckBox Content="{Binding Texts[Copilot.Option.BattleList]}"
                          IsChecked="{Binding UseCopilotList}" />
                <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                      Tip="{Binding Texts[Copilot.Tip.BattleList]}" />
              </StackPanel>

              <CheckBox Content="{Binding Texts[Copilot.Option.UseSanityPotion]}"
                        IsChecked="{Binding UseSanityPotion}"
                        IsVisible="{Binding ShowUseSanityPotion}" />

              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowLoopSetting}">
                <CheckBox Content="{Binding Texts[Copilot.Option.LoopTimes]}"
                          IsChecked="{Binding Loop}" />
                <controls:VerticalSpinNumberBox Margin="8,0,0,0"
                                                Minimum="1"
                                                Maximum="9999"
                                                Value="{Binding LoopTimes}" />
              </StackPanel>
            </StackPanel>
          </Grid>

          <Grid Grid.Column="1"
                Margin="12,10,0,0"
                IsVisible="{Binding ShowCopilotListPanel}"
                RowDefinitions="*,Auto"
                ColumnDefinitions="Auto,*,Auto,Auto">
            <Border Grid.Row="0"
                    Grid.ColumnSpan="4"
                    Classes="wpf-card">
              <ListBox x:Name="CopilotList"
                       ItemsSource="{Binding Items}"
                       SelectedItem="{Binding SelectedItem}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="4,2">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <CheckBox Content="{Binding DisplayName}"
                                  IsChecked="{Binding IsChecked}"
                                  ToolTip.Tip="{Binding ExecutionPathHint}" />
                        <Button Grid.Column="1"
                                Classes="wpf-button wpf-button-secondary copilot-list-action"
                                Margin="8,0,0,0"
                                Content="{Binding DataContext.Texts[Copilot.Button.Load], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding}"
                                Click="OnLoadListItemClick"
                                PointerPressed="OnLoadListItemPointerPressed" />
                        <Button Grid.Column="2"
                                Classes="wpf-button wpf-button-secondary copilot-list-action"
                                Margin="8,0,0,0"
                                Content="{Binding DataContext.Texts[Copilot.Button.Delete], RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding}"
                                Click="OnDeleteListItemClick" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Classes="wpf-button wpf-button-secondary copilot-list-action"
                    Content="{Binding Texts[Copilot.Button.ImportBatch]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.ImportBatch]}"
                    Click="OnImportFilesClick"
                    IsEnabled="{Binding CanEdit}" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="8,0,0,0"
                     Text="{Binding CopilotTaskName}"
                     Watermark="{Binding Texts[Copilot.Input.StageNameWatermark]}"
                     ToolTip.Tip="{Binding Texts[Copilot.Tip.StageName]}" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Classes="wpf-button wpf-button-secondary copilot-list-action"
                    Margin="8,0,0,0"
                    Content="{Binding Texts[Copilot.Button.Add]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.AddList]}"
                    Click="OnAddCurrentToListClick"
                    PointerPressed="OnAddCurrentToListPointerPressed"
                    IsEnabled="{Binding CanEdit}" />
            <Button Grid.Row="1"
                    Grid.Column="3"
                    Classes="wpf-button wpf-button-secondary copilot-list-action"
                    Margin="8,0,0,0"
                    Content="{Binding Texts[Copilot.Button.Clear]}"
                    ToolTip.Tip="{Binding Texts[Copilot.Tip.ClearList]}"
                    Click="OnClearListClick"
                    PointerPressed="OnClearListPointerPressed"
                    IsEnabled="{Binding CanEdit}" />
          </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   Text="{Binding CopilotUrl}" />
      </Grid>
    </Border>

    <Border Grid.Column="2" Classes="wpf-panel">
      <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid HorizontalAlignment="Right">
          <Button Classes="wpf-button wpf-button-secondary overlay-toggle"
                  ToolTip.Tip="{Binding DataContext.TaskQueuePage.OverlayButtonToolTip, RelativeSource={RelativeSource AncestorType=Window}}"
                  Click="OnToggleOverlayClick"
                  PointerPressed="OnOverlayButtonPointerPressed">
            <StackPanel Orientation="Horizontal"
                        Spacing="{DynamicResource MAA.Spacing.Tight}">
              <Border Classes="overlay-indicator"
                      Classes.mode-hidden="{Binding DataContext.TaskQueuePage.IsOverlayHiddenMode, RelativeSource={RelativeSource AncestorType=Window}}"
                      Classes.mode-preview="{Binding DataContext.TaskQueuePage.IsOverlayPreviewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                      Classes.mode-native="{Binding DataContext.TaskQueuePage.IsOverlayNativeMode, RelativeSource={RelativeSource AncestorType=Window}}" />
              <TextBlock Text="{Binding DataContext.TaskQueuePage.RootTexts[TaskQueue.Root.OverlayButton], RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
          </Button>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="0,6,0,8"
                    Spacing="{DynamicResource MAA.Spacing.Tight}">
          <TextBlock Text="{Binding StatusMessage}" />
          <TextBlock Classes="state-error"
                     Text="{Binding LastErrorMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Text="{Binding ListSelectionHint}"
                     Opacity="0.72"
                     TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Logs}" />
        </ScrollViewer>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto,Auto"
              IsVisible="{Binding CouldLikeWebJson}">
          <TextBlock Margin="0,10,0,0"
                     VerticalAlignment="Center"
                     Text="{Binding Texts[Copilot.Rating.Prompt]}"
                     TextWrapping="Wrap" />
          <Button Grid.Column="1"
                  Classes="wpf-button wpf-button-secondary"
                  Margin="8,10,0,0"
                  Content="{Binding Texts[Copilot.Button.Like]}"
                  Click="OnLikeLoadedClick" />
          <Button Grid.Column="2"
                  Classes="wpf-button wpf-button-secondary"
                  Margin="8,10,0,0"
                  Content="{Binding Texts[Copilot.Button.Dislike]}"
                  Click="OnDislikeLoadedClick" />
        </Grid>

        <TextBlock Grid.Row="4"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   Text="{Binding MapUrl}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
