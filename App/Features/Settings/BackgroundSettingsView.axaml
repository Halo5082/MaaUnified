<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.BackgroundSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
    <Grid ColumnDefinitions="Auto,*">
      <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Background]}" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-warning"
                 Text="{Binding RootTexts[Settings.State.Saving]}"
                 IsVisible="{Binding IsGuiSaveInProgress}" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-success"
                 Text="{Binding RootTexts[Settings.State.Saved]}"
                 IsVisible="{Binding HasGuiSaveSucceeded}" />
    </Grid>
    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <TextBlock Classes="settings-field-caption" Text="背景图片" />
      <Grid Width="{DynamicResource MAA.Size.Settings.FieldPathWidth}"
            ColumnDefinitions="*,Auto">
        <TextBox Text="{Binding BackgroundImagePath, UpdateSourceTrigger=LostFocus}"
                 LostFocus="OnBackgroundPathLostFocus"
                 KeyDown="OnBackgroundPathKeyDown" />
        <Button Grid.Column="1"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="选择" />
      </Grid>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <TextBlock Classes="settings-field-caption" Text="背景不透明度" />
      <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                      Minimum="0"
                                      Maximum="100"
                                      Value="{Binding BackgroundOpacity}" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <TextBlock Classes="settings-field-caption" Text="背景模糊半径" />
      <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                      Minimum="0"
                                      Maximum="80"
                                      Value="{Binding BackgroundBlur}" />
    </StackPanel>

    <StackPanel Grid.Row="4"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <TextBlock Classes="settings-field-caption" Text="背景填充模式" />
      <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                ItemsSource="{Binding BackgroundStretchModes}"
                SelectedItem="{Binding SelectedBackgroundStretchModeOption}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DisplayValueOption">
            <TextBlock Text="{Binding Display}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Grid.Row="5"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding BackgroundValidationMessage}"
                 IsVisible="{Binding HasBackgroundValidationMessage}" />
      <TextBlock Classes="settings-note settings-centered-text"
                 Text="背景图与模糊参数与 Windows 保持同名配置键。若路径不存在，将阻断本次 GUI 保存。" />
    </StackPanel>
  </Grid>
</UserControl>
