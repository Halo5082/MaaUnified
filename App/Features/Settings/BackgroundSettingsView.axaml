<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.BackgroundSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Background" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
      <TextBlock VerticalAlignment="Center" Text="背景图路径" />
      <TextBox Text="{Binding BackgroundImagePath}"
               LostFocus="OnBackgroundPathLostFocus"
               KeyDown="OnBackgroundPathKeyDown" />
      <Button Grid.Column="2" Content="选择" />
    </Grid>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,120,Auto,120,Auto,140">
      <TextBlock VerticalAlignment="Center" Text="透明度(0-100)" />
      <NumericUpDown Minimum="0" Maximum="100" Value="{Binding BackgroundOpacity}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="模糊" />
      <NumericUpDown Grid.Column="3" Minimum="0" Maximum="80" Value="{Binding BackgroundBlur}" />
      <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="拉伸模式" />
      <ComboBox Grid.Column="5"
                ItemsSource="{Binding BackgroundStretchModes}"
                SelectedItem="{Binding BackgroundStretchMode}" />
    </Grid>
    <TextBlock Grid.Row="3" Classes="state-warning" Text="{Binding GuiValidationMessage}" IsVisible="{Binding HasGuiValidationMessage}" />
    <TextBlock Grid.Row="4" Classes="state-warning" Text="存在未保存的 GUI 变更。" IsVisible="{Binding HasPendingGuiChanges}" />
    <TextBlock Grid.Row="5" Text="背景图与模糊参数与 Windows 保持同名配置键。若路径不存在，将阻断本次 GUI 保存。" />
  </Grid>
</UserControl>
