<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.StartSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Start" />
    <WrapPanel Grid.Row="1" ItemWidth="200">
      <CheckBox Content="开机启动" IsChecked="{Binding StartSelf}" />
      <CheckBox Content="启动后最小化" />
      <CheckBox Content="自动开模拟器" />
      <CheckBox Content="自动重连" />
    </WrapPanel>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,260,Auto,220">
      <TextBlock VerticalAlignment="Center" Text="模拟器路径" />
      <TextBox />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="附加参数" />
      <TextBox Grid.Column="3" />
    </Grid>
    <TextBlock Grid.Row="3" Text="重连策略与等待时间在连接页联动配置。" />
    <TextBlock Grid.Row="4" Text="{Binding AutostartStatus}" />
  </Grid>
</UserControl>
