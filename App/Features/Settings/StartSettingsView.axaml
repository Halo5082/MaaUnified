<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Settings.StartSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <Grid ColumnDefinitions="Auto,*">
      <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Start]}" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-warning"
                 Text="{Binding RootTexts[Settings.State.Saving]}"
                 IsVisible="{Binding IsStartPerformanceSaveInProgress}" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-success"
                 Text="{Binding RootTexts[Settings.State.Saved]}"
                 IsVisible="{Binding HasStartPerformanceSaveSucceeded}" />
    </Grid>

    <Grid Grid.Row="1"
          Classes="settings-form"
          Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
          ColumnDefinitions="260,320">
      <StackPanel Grid.Column="0"
                  Classes="settings-centered-column"
                  Spacing="{DynamicResource MAA.Spacing.Small}">
        <Grid ColumnDefinitions="Auto,Auto">
          <CheckBox Content="{Binding RootTexts[Settings.Start.AutoStartMaa]}" IsChecked="{Binding StartSelf}" />
          <controls:TooltipHint Grid.Column="1"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                Tip="{Binding RootTexts[Settings.Start.AutoStartMaaTip]}" />
        </Grid>

        <StackPanel Spacing="0">
          <CheckBox Content="{Binding RootTexts[Settings.Start.MinimizeDirectly]}" IsChecked="{Binding MinimizeDirectly}" />
          <TextBlock Classes="settings-apply-note"
                     Margin="{DynamicResource MAA.Thickness.Settings.CheckboxNoteIndent}"
                     Text="{Binding RootTexts[Settings.Start.ApplyOnNextLaunch]}" />
        </StackPanel>

        <Border Height="1"
                Margin="0,6,0,6"
                Background="{DynamicResource MAA.Brush.Border.Default}" />

        <StackPanel Spacing="0">
          <CheckBox Content="{Binding RootTexts[Settings.Start.RunDirectly]}" IsChecked="{Binding RunDirectly}" />
          <TextBlock Classes="settings-apply-note"
                     Margin="{DynamicResource MAA.Thickness.Settings.CheckboxNoteIndent}"
                     Text="{Binding RootTexts[Settings.Start.ApplyOnNextLaunch]}" />
        </StackPanel>

        <StackPanel Spacing="0">
          <CheckBox Content="{Binding RootTexts[Settings.Start.AutoOpenEmulator]}" IsChecked="{Binding OpenEmulatorAfterLaunch}" />
          <TextBlock Classes="settings-apply-note"
                     Margin="{DynamicResource MAA.Thickness.Settings.CheckboxNoteIndent}"
                     Text="{Binding RootTexts[Settings.Start.ApplyOnNextExecution]}" />
        </StackPanel>

        <Grid ColumnDefinitions="Auto,Auto">
          <CheckBox Content="{Binding RootTexts[Settings.Start.RetryOnDisconnected]}"
                    IsChecked="{Binding ConnectionGameSharedState.RetryOnDisconnected}" />
          <controls:TooltipHint Grid.Column="1"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                Tip="{Binding RootTexts[Settings.Start.RetryOnDisconnectedTip]}" />
        </Grid>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Classes="settings-centered-column"
                  Spacing="{DynamicResource MAA.Spacing.Large}"
                  IsVisible="{Binding CanEditEmulatorLaunchSettings}">
        <StackPanel Classes="settings-centered-column">
          <Grid HorizontalAlignment="Center"
                ColumnDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Column="0"
                       Classes="settings-field-caption"
                       Margin="0"
                       Text="{Binding RootTexts[Settings.Start.EmulatorPath]}" />
            <controls:TooltipHint Grid.Column="1" Tip="{Binding RootTexts[Settings.Start.EmulatorPathTip]}" />
            <Button Grid.Column="2"
                    Classes="wpf-button wpf-button-secondary compact"
                    Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                    Content="{Binding RootTexts[Settings.Start.SelectButton]}"
                    Click="OnSelectEmulatorPathClick" />
          </Grid>
          <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                   Text="{Binding EmulatorPath, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <StackPanel Classes="settings-centered-column">
          <Grid HorizontalAlignment="Center"
                ColumnDefinitions="Auto,Auto">
            <TextBlock Grid.Column="0"
                       Classes="settings-field-caption"
                       Margin="0"
                       Text="{Binding RootTexts[Settings.Start.EmulatorExtraArgs]}" />
            <controls:TooltipHint Grid.Column="1" Tip="{Binding RootTexts[Settings.Start.EmulatorExtraArgsTip]}" />
          </Grid>
          <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                   IsEnabled="{Binding CanEditEmulatorLaunchSettings}"
                   Text="{Binding EmulatorAddCommand, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <StackPanel Classes="settings-centered-column" Spacing="0">
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="{DynamicResource MAA.Spacing.Small}">
            <TextBlock VerticalAlignment="Center" Text="{Binding RootTexts[Settings.Start.EmulatorWaitSeconds]}" />
            <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldTinyWidth}"
                                            Minimum="0"
                                            Maximum="600"
                                            Value="{Binding EmulatorWaitSeconds}" />
          </StackPanel>
          <TextBlock Classes="settings-apply-note settings-centered-text" Text="{Binding RootTexts[Settings.Start.EmulatorWaitSecondsNote]}" />
        </StackPanel>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="3"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding StartPerformanceValidationMessage}"
                 IsVisible="{Binding HasStartPerformanceValidationMessage}" />
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding AutostartWarningMessage}"
                 IsVisible="{Binding HasAutostartWarningMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding AutostartErrorMessage}"
                 IsVisible="{Binding HasAutostartErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
