<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Settings.StartSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <Grid ColumnDefinitions="Auto,*">
      <TextBlock Classes="section-title" Text="启动设置" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-warning"
                 Text="正在保存..."
                 IsVisible="{Binding IsStartPerformanceSaveInProgress}" />
      <TextBlock Grid.Column="1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Classes="state-success"
                 Text="保存成功"
                 IsVisible="{Binding HasStartPerformanceSaveSucceeded}" />
    </Grid>

    <WrapPanel Grid.Row="1"
               Classes="settings-wrap"
               Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
               ItemWidth="280">
      <StackPanel Spacing="2">
        <Grid ColumnDefinitions="Auto,Auto">
          <CheckBox Content="随系统启动" IsChecked="{Binding StartSelf}" />
          <controls:TooltipHint Grid.Column="1"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                Tip="该选项在多配置时为全局设置。切换配置不会改变开机启动状态。" />
        </Grid>
      </StackPanel>
      <StackPanel Spacing="2">
        <CheckBox Content="启动后执行任务" IsChecked="{Binding RunDirectly}" />
        <TextBlock Classes="settings-note" Text="下次启动生效" />
      </StackPanel>
      <StackPanel Spacing="2">
        <CheckBox Content="启动后最小化" IsChecked="{Binding MinimizeDirectly}" />
        <TextBlock Classes="settings-note" Text="下次启动生效" />
      </StackPanel>
      <StackPanel Spacing="2">
        <CheckBox Content="自动启动模拟器" IsChecked="{Binding OpenEmulatorAfterLaunch}" />
        <TextBlock Classes="settings-note" Text="下次执行生效" />
      </StackPanel>
      <StackPanel Spacing="2">
        <Grid ColumnDefinitions="Auto,Auto">
          <CheckBox Content="ADB 断开后自动重试连接"
                    IsChecked="{Binding ConnectionGameSharedState.RetryOnDisconnected}" />
          <controls:TooltipHint Grid.Column="1"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                Tip="启用后将在检测到连接断开时自动尝试重连；需要先配置有效的模拟器路径。" />
        </Grid>
      </StackPanel>
    </WrapPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-form"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                IsVisible="{Binding CanEditEmulatorLaunchSettings}">
      <Grid ColumnDefinitions="132,*,Auto">
        <TextBlock Classes="settings-label" Text="模拟器路径" />
        <TextBox Grid.Column="1"
                 Text="{Binding EmulatorPath, UpdateSourceTrigger=LostFocus}"
                 Watermark="/path/to/emulator" />
        <Button Grid.Column="2"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="选择路径"
                Click="OnSelectEmulatorPathClick" />
      </Grid>

      <Grid ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label" Text="附加参数" />
        <TextBox Grid.Column="1" Text="{Binding EmulatorAddCommand, UpdateSourceTrigger=LostFocus}" />
      </Grid>

      <Grid ColumnDefinitions="132,120,Auto">
        <TextBlock Classes="settings-label" Text="等待秒数" />
        <controls:VerticalSpinNumberBox Grid.Column="1"
                                        Minimum="0"
                                        Maximum="600"
                                        Value="{Binding EmulatorWaitSeconds}" />
        <TextBlock Grid.Column="2"
                   Margin="{DynamicResource MAA.Thickness.Settings.FieldGap}"
                   Classes="settings-note"
                   Text="范围 0-600，下次执行生效" />
      </Grid>
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="state-warning"
                 Text="{Binding StartPerformanceValidationMessage}"
                 IsVisible="{Binding HasStartPerformanceValidationMessage}" />
      <TextBlock Text="{Binding AutostartStatus}" />
    </StackPanel>
  </Grid>
</UserControl>
