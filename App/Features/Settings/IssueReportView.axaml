<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.IssueReportView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Issue Report" />
    <WrapPanel Grid.Row="1" ItemWidth="180">
      <Button Content="帮助文档" Click="OnOpenHelpClick" />
      <Button Content="Issue 入口" Click="OnOpenIssueEntryClick" />
      <Button Content="生成支持包" Click="OnBuildIssueReportClick" />
      <Button Content="打开 debug 目录" Click="OnOpenDebugDirectoryClick" />
      <Button Content="清理图像缓存" Click="OnClearImageCacheClick" />
    </WrapPanel>
    <TextBlock Grid.Row="2" Classes="long-wrap" Text="{Binding IssueReportPath}" />
    <TextBlock Grid.Row="3" Classes="long-wrap" Text="{Binding IssueReportStatusMessage}" />
    <TextBlock Grid.Row="4"
               Classes="state-error long-wrap"
               Text="{Binding IssueReportErrorMessage}"
               IsVisible="{Binding HasIssueReportErrorMessage}" />
  </Grid>
</UserControl>
