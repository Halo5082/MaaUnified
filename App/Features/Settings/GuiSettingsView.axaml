<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.GuiSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="GUI" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,120,Auto,120,Auto,140">
      <TextBlock VerticalAlignment="Center" Text="主题" />
      <ComboBox SelectedItem="{Binding Theme}">
        <ComboBoxItem Content="Light" />
        <ComboBoxItem Content="Dark" />
      </ComboBox>
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="语言" />
      <TextBox Grid.Column="3" Text="{Binding Language}" />
      <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="日志模式" />
      <ComboBox Grid.Column="5" SelectedIndex="0">
        <ComboBoxItem Content="普通日志" />
        <ComboBoxItem Content="卡片日志" />
      </ComboBox>
    </Grid>
    <WrapPanel Grid.Row="2" ItemWidth="220">
      <CheckBox Content="启用托盘" IsChecked="{Binding UseTray}" />
      <CheckBox Content="最小化到托盘" IsChecked="{Binding MinimizeToTray}" />
      <CheckBox Content="标题滚动" IsChecked="{Binding WindowTitleScrollable}" />
      <CheckBox Content="坏模块渲染策略：报错可见" IsChecked="True" />
    </WrapPanel>
    <TextBlock Grid.Row="3" Text="隐藏/菜单行为保持与 Windows 客户端一致。" />
  </Grid>
</UserControl>
