<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.AchievementSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="成就设置" />
    <WrapPanel Grid.Row="1"
               Classes="settings-wrap"
               Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
               ItemWidth="240">
      <Button Classes="wpf-button wpf-button-secondary" Content="刷新成就状态" Click="OnRefreshAchievementClick" />
      <Button Classes="wpf-button wpf-button-secondary" Content="打开成就说明" Click="OnOpenAchievementGuideClick" />
      <Button Classes="wpf-button wpf-button-secondary" Content="查看成就列表" Click="OnShowAchievementListClick" />
      <CheckBox Content="禁用成就弹窗" IsChecked="{Binding AchievementPopupDisabled}" />
      <CheckBox Content="成就弹窗自动关闭"
                IsChecked="{Binding AchievementPopupAutoClose}"
                IsVisible="{Binding CanEditAchievementPopupAutoClose}" />
    </WrapPanel>
    <StackPanel Grid.Row="2"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="long-wrap" Text="{Binding AchievementPolicySummary}" />
      <TextBlock Classes="settings-note"
                 Text="成就配置变更会写入 avalonia.json，可通过 Issue Report 导出诊断信息。" />
    </StackPanel>
    <StackPanel Grid.Row="3"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Text="{Binding AchievementStatusMessage}" />
      <TextBlock Classes="state-error"
                 Text="{Binding AchievementErrorMessage}"
                 IsVisible="{Binding HasAchievementErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
