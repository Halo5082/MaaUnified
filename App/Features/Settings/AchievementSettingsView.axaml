<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.AchievementSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Achievement]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Spacing="{DynamicResource MAA.Spacing.Small}">
      <TextBlock Classes="settings-centered-text"
                 FontWeight="SemiBold"
                 Text="{Binding AchievementLevelText}" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Small}">
        <Button Classes="wpf-button wpf-button-secondary" Content="刷新成就状态" Click="OnRefreshAchievementClick" />
        <Button Classes="wpf-button wpf-button-secondary"
                Content="查看成就"
                Click="OnShowAchievementListClick" />
      </StackPanel>
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Small}">
        <Button Classes="wpf-button wpf-button-secondary"
                Content="备份成就"
                Click="OnBackupAchievementClick" />
        <Button Classes="wpf-button wpf-button-secondary"
                Content="加载备份"
                Click="OnRestoreAchievementClick" />
        <Button Classes="wpf-button wpf-button-secondary"
                Content="打开成就说明"
                Click="OnOpenAchievementGuideClick" />
      </StackPanel>
      <Border Width="108"
              Height="108"
              Padding="8"
              CornerRadius="54"
              HorizontalAlignment="Center"
              Background="#1AFFFFFF"
              BorderBrush="{Binding AchievementDebugMedalColor}"
              BorderThickness="2"
              PointerPressed="OnAchievementDebugPointerPressed">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{Binding AchievementDebugMedalColor}"
                   Text="MAA" />
      </Border>
      <TextBlock Classes="settings-centered-text subtle"
                 Text="{Binding AchievementDebugTip}" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Small}"
                  IsVisible="{Binding CanUseAchievementDebugActions}">
        <Button Classes="wpf-button wpf-button-secondary"
                Content="Unlock All"
                Click="OnUnlockAllAchievementClick" />
        <Button Classes="wpf-button wpf-button-secondary"
                Content="Lock All"
                Click="OnLockAllAchievementClick" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text long-wrap" Text="{Binding AchievementPolicySummary}" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="0">
      <CheckBox Margin="{DynamicResource MAA.Thickness.Settings.ItemMarginSmall}"
                HorizontalAlignment="Center"
                Content="禁用成就提示气泡"
                IsChecked="{Binding AchievementPopupDisabled}" />
      <CheckBox Margin="{DynamicResource MAA.Thickness.Settings.ItemMarginSmall}"
                HorizontalAlignment="Center"
                Content="成就提示气泡自动关闭"
                IsChecked="{Binding AchievementPopupAutoClose}"
                IsVisible="{Binding CanEditAchievementPopupAutoClose}" />
    </StackPanel>

    <StackPanel Grid.Row="4"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text" Text="{Binding AchievementStatusMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding AchievementErrorMessage}"
                 IsVisible="{Binding HasAchievementErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
