<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.GameSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Game]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <TextBlock Classes="settings-field-caption" Text="客户端类型" />
      <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                ItemsSource="{Binding ConnectionGameSharedState.ClientTypeOptions}"
                SelectedItem="{Binding ConnectionGameSharedState.SelectedClientTypeOption}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
            <TextBlock Text="{Binding DisplayName}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <CheckBox Content="划火柴模式（自动战斗相关）（不稳定，暂不推荐开启）"
                HorizontalAlignment="Center"
                IsChecked="{Binding DeploymentWithPause}" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,Auto">
        <TextBlock Grid.Column="0"
                   Classes="settings-field-caption"
                   Margin="0"
                   Text="开始前脚本" />
        <controls:TooltipHint Grid.Column="1" Tip="示例：&quot;C:\1.cmd&quot; -minimized" />
      </Grid>
      <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
               Text="{Binding StartsWithScript, UpdateSourceTrigger=LostFocus}" />
    </StackPanel>

    <StackPanel Grid.Row="4"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,Auto">
        <TextBlock Grid.Column="0"
                   Classes="settings-field-caption"
                   Margin="0"
                   Text="结束后脚本" />
        <controls:TooltipHint Grid.Column="1" Tip="示例：&quot;C:\1.cmd&quot; -noWindow" />
      </Grid>
      <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
               Text="{Binding EndsWithScript, UpdateSourceTrigger=LostFocus}" />
    </StackPanel>

    <StackPanel Grid.Row="5"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="自动战斗时启用上述脚本" IsChecked="{Binding CopilotWithScript}" />
        <CheckBox Content="手动暂停时启用上述脚本" IsChecked="{Binding ManualStopWithScript}" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="6"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="运行任务时阻止休眠" IsChecked="{Binding BlockSleep}" />
        <CheckBox Content="阻止休眠时保持屏幕常亮"
                  IsChecked="{Binding BlockSleepWithScreenOn}"
                  IsVisible="{Binding ShowBlockSleepWithScreenOnOption}" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="7"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="上报企鹅物流" IsChecked="{Binding EnablePenguin}" />
        <CheckBox Content="上报一图流" IsChecked="{Binding EnableYituliu}" />
      </StackPanel>
      <StackPanel Classes="settings-centered-column"
                  Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                  IsVisible="{Binding ShowPenguinIdField}">
        <TextBlock Classes="settings-field-caption" Text="企鹅物流汇报 ID（仅数字部分）" />
        <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                 Text="{Binding PenguinId, UpdateSourceTrigger=LostFocus}" />
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="8"
          Classes="settings-form"
          Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
          ColumnDefinitions="250,250">
      <StackPanel Grid.Column="0" Classes="settings-centered-column">
        <TextBlock Classes="settings-field-caption" Text="任务超时时间（分钟）" />
        <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                        Minimum="0"
                                        Maximum="1440"
                                        Value="{Binding TaskTimeoutMinutes}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Classes="settings-centered-column">
        <TextBlock Classes="settings-field-caption" Text="提醒间隔时间（分钟）" />
        <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                        Minimum="1"
                                        Maximum="1440"
                                        Value="{Binding ReminderIntervalMinutes}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
