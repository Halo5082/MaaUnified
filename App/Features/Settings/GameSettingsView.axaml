<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.GameSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Game" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,220,Auto,220" Margin="0,6,0,0">
      <TextBlock VerticalAlignment="Center" Text="客户端类型" />
      <ComboBox ItemsSource="{Binding ClientTypeOptions}" SelectedItem="{Binding ClientType}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="自动启动游戏" />
      <CheckBox Grid.Column="3"
                VerticalAlignment="Center"
                IsChecked="{Binding StartGameEnabled}"
                IsEnabled="{Binding CanStartGameEnabled}" />
    </Grid>
    <TextBlock Grid.Row="2"
               Margin="0,8,0,0"
               Opacity="0.7"
               Text="提示：Connect Config 为 PC 时，自动启动游戏会在所有页面中保持禁用并强制为 false。" />
  </Grid>
</UserControl>
