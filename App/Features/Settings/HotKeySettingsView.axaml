<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.HotKeySettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="HotKey" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,160,Auto,160,Auto">
      <TextBlock VerticalAlignment="Center" Text="显示 GUI" />
      <TextBox Text="{Binding HotkeyShowGui}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="LinkStart" />
      <TextBox Grid.Column="3" Text="{Binding HotkeyLinkStart}" />
      <Button Grid.Column="4" Content="应用热键" Click="OnApplyHotkeysClick" />
    </Grid>
    <TextBlock Grid.Row="2" Text="{Binding HotkeyStatusMessage}" />
    <TextBlock Grid.Row="3" Classes="state-warning" Text="{Binding HotkeyWarningMessage}" IsVisible="{Binding HasHotkeyWarningMessage}" />
    <TextBlock Grid.Row="4" Classes="state-error" Text="{Binding HotkeyErrorMessage}" IsVisible="{Binding HasHotkeyErrorMessage}" />
  </Grid>
</UserControl>
