<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.HotKeySettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.HotKey]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Spacing="{DynamicResource MAA.Spacing.Small}">
      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,160,Auto">
        <TextBlock Margin="{DynamicResource MAA.Thickness.Settings.ItemMargin}"
                   VerticalAlignment="Center"
                   Text="[热键] 显示/收起 MAA" />
        <TextBox Grid.Column="1"
                 Width="160"
                 VerticalAlignment="Center"
                 Text="{Binding HotkeyShowGui, UpdateSourceTrigger=LostFocus}" />
      </Grid>

      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,160,Auto">
        <TextBlock Margin="{DynamicResource MAA.Thickness.Settings.ItemMargin}"
                   VerticalAlignment="Center"
                   Text="[热键] Link start/stop" />
        <TextBox Grid.Column="1"
                 Width="160"
                 VerticalAlignment="Center"
                 Text="{Binding HotkeyLinkStart, UpdateSourceTrigger=LostFocus}" />
      </Grid>

      <Button Classes="wpf-button wpf-button-secondary"
              HorizontalAlignment="Center"
              Content="{Binding RootTexts[Settings.Action.RegisterHotkeys]}"
              Click="OnApplyHotkeysClick" />
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text" Text="{Binding HotkeyStatusMessage}" />
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding HotkeyWarningMessage}"
                 IsVisible="{Binding HasHotkeyWarningMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding HotkeyErrorMessage}"
                 IsVisible="{Binding HasHotkeyErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
