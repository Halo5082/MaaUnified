<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.HotKeySettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="HotKey" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,160,Auto,160,Auto">
      <TextBlock VerticalAlignment="Center" Text="显示 GUI" />
      <TextBox Text="{Binding HotkeyShowGui}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="LinkStart" />
      <TextBox Grid.Column="3" Text="{Binding HotkeyLinkStart}" />
      <Button Grid.Column="4" Content="应用热键" />
    </Grid>
    <TextBlock Grid.Row="2" Text="全局热键注册失败会明确报错并写入 debug 日志。" />
  </Grid>
</UserControl>
