<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.HotKeySettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.HotKey]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Spacing="10">
      <TextBlock Classes="settings-centered-text"
                 Text="{Binding HotkeyCaptureGuideText}"
                 TextWrapping="Wrap" />

      <Border Padding="12"
              BorderBrush="Gray"
              BorderThickness="1"
              CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,Auto"
              ColumnDefinitions="2*,180,Auto,Auto,Auto">
          <TextBlock Grid.Row="0"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="{Binding ShowGuiHotkeyState.Title}" />
          <TextBox x:Name="ShowGuiCaptureBox"
                   Grid.Row="0"
                   Grid.Column="1"
                   Margin="0,0,8,0"
                   IsReadOnly="True"
                   Tag="ShowGui"
                   Text="{Binding ShowGuiHotkeyState.InputText}"
                   KeyDown="OnHotkeyCaptureKeyDown" />
          <Button Grid.Row="0"
                  Grid.Column="2"
                  Margin="0,0,8,0"
                  Classes="wpf-button wpf-button-secondary"
                  Tag="ShowGui"
                  Content="{Binding ShowGuiHotkeyState.CaptureButtonText}"
                  Click="OnBeginCaptureClick" />
          <Button Grid.Row="0"
                  Grid.Column="3"
                  Margin="0,0,8,0"
                  Classes="wpf-button wpf-button-secondary"
                  Tag="ShowGui"
                  Content="{Binding ShowGuiHotkeyState.ClearButtonText}"
                  Click="OnClearHotkeyClick" />
          <TextBlock Grid.Row="0"
                     Grid.Column="4"
                     VerticalAlignment="Center"
                     Text="{Binding ShowGuiHotkeyState.ScopeLabel}" />

          <TextBlock Grid.Row="1"
                     Grid.Column="0"
                     Grid.ColumnSpan="5"
                     Classes="state-warning"
                     IsVisible="{Binding ShowGuiHotkeyState.HasWarningMessage}"
                     Text="{Binding ShowGuiHotkeyState.WarningMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Grid.Row="2"
                     Grid.Column="0"
                     Grid.ColumnSpan="5"
                     Classes="state-error"
                     IsVisible="{Binding ShowGuiHotkeyState.HasErrorMessage}"
                     Text="{Binding ShowGuiHotkeyState.ErrorMessage}"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>

      <Border Padding="12"
              BorderBrush="Gray"
              BorderThickness="1"
              CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,Auto"
              ColumnDefinitions="2*,180,Auto,Auto,Auto">
          <TextBlock Grid.Row="0"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center"
                     Text="{Binding LinkStartHotkeyState.Title}" />
          <TextBox x:Name="LinkStartCaptureBox"
                   Grid.Row="0"
                   Grid.Column="1"
                   Margin="0,0,8,0"
                   IsReadOnly="True"
                   Tag="LinkStart"
                   Text="{Binding LinkStartHotkeyState.InputText}"
                   KeyDown="OnHotkeyCaptureKeyDown" />
          <Button Grid.Row="0"
                  Grid.Column="2"
                  Margin="0,0,8,0"
                  Classes="wpf-button wpf-button-secondary"
                  Tag="LinkStart"
                  Content="{Binding LinkStartHotkeyState.CaptureButtonText}"
                  Click="OnBeginCaptureClick" />
          <Button Grid.Row="0"
                  Grid.Column="3"
                  Margin="0,0,8,0"
                  Classes="wpf-button wpf-button-secondary"
                  Tag="LinkStart"
                  Content="{Binding LinkStartHotkeyState.ClearButtonText}"
                  Click="OnClearHotkeyClick" />
          <TextBlock Grid.Row="0"
                     Grid.Column="4"
                     VerticalAlignment="Center"
                     Text="{Binding LinkStartHotkeyState.ScopeLabel}" />

          <TextBlock Grid.Row="1"
                     Grid.Column="0"
                     Grid.ColumnSpan="5"
                     Classes="state-warning"
                     IsVisible="{Binding LinkStartHotkeyState.HasWarningMessage}"
                     Text="{Binding LinkStartHotkeyState.WarningMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Grid.Row="2"
                     Grid.Column="0"
                     Grid.ColumnSpan="5"
                     Classes="state-error"
                     IsVisible="{Binding LinkStartHotkeyState.HasErrorMessage}"
                     Text="{Binding LinkStartHotkeyState.ErrorMessage}"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>

      <Button Classes="wpf-button wpf-button-secondary"
              HorizontalAlignment="Center"
              Content="{Binding RootTexts[Settings.Action.RegisterHotkeys]}"
              Click="OnApplyHotkeysClick" />
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text" Text="{Binding HotkeyStatusMessage}" />
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding HotkeyWarningMessage}"
                 IsVisible="{Binding HasHotkeyWarningMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding HotkeyErrorMessage}"
                 IsVisible="{Binding HasHotkeyErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
