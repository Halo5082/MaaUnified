<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.RemoteControlSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Remote Control" />
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
      <TextBlock VerticalAlignment="Center" Text="拉任务接口" />
      <TextBox Text="{Binding RemoteGetTaskEndpoint}" Watermark="https://example.com/get-task" />
    </Grid>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
      <TextBlock VerticalAlignment="Center" Text="上报接口" />
      <TextBox Text="{Binding RemoteReportEndpoint}" Watermark="https://example.com/report" />
    </Grid>
    <Grid Grid.Row="3" ColumnDefinitions="Auto,120,Auto,180,Auto,Auto">
      <TextBlock VerticalAlignment="Center" Text="轮询间隔(ms)" />
      <NumericUpDown Minimum="500" Maximum="60000" Value="{Binding RemotePollInterval}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="用户/设备标识" />
      <TextBox Grid.Column="3" Watermark="userId-deviceId" />
      <Button Grid.Column="4" Content="连通测试" />
      <Button Grid.Column="5" Content="文档入口" />
    </Grid>
  </Grid>
</UserControl>
