<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Settings.RemoteControlSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto">
    <TextBlock Classes="section-title" Text="远程控制" />
    <StackPanel Grid.Row="1"
                Classes="settings-form"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <Grid ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label" Text="拉任务接口" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteGetTaskEndpoint, UpdateSourceTrigger=LostFocus}"
                 Watermark="https://example.com/get-task" />
      </Grid>

      <Grid ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label" Text="上报接口" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteReportEndpoint, UpdateSourceTrigger=LostFocus}"
                 Watermark="https://example.com/report" />
      </Grid>

      <Grid ColumnDefinitions="132,120,Auto">
        <TextBlock Classes="settings-label" Text="轮询间隔(ms)" />
        <controls:VerticalSpinNumberBox Grid.Column="1"
                                        Minimum="500"
                                        Maximum="60000"
                                        Value="{Binding RemotePollInterval}" />
        <Button Grid.Column="2"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="连通测试"
                Click="OnTestRemoteConnectivityClick" />
      </Grid>

      <Grid ColumnDefinitions="132,220,132,220">
        <TextBlock Classes="settings-label" Text="用户标识" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteUserIdentity, UpdateSourceTrigger=LostFocus}"
                 Watermark="remote-user-id" />
        <TextBlock Grid.Column="2" Classes="settings-label" Text="设备标识" />
        <TextBox Grid.Column="3"
                 Text="{Binding RemoteDeviceIdentity, UpdateSourceTrigger=LostFocus}"
                 Watermark="remote-device-id" />
      </Grid>

      <StackPanel Classes="settings-form settings-form-narrow" Spacing="4">
        <TextBlock Text="{Binding RemoteControlStatusMessage}" />
        <TextBlock Classes="state-warning"
                   Text="{Binding RemoteControlWarningMessage}"
                   IsVisible="{Binding HasRemoteControlWarningMessage}" />
        <TextBlock Classes="state-error"
                   Text="{Binding RemoteControlErrorMessage}"
                   IsVisible="{Binding HasRemoteControlErrorMessage}" />
        <TextBlock Classes="settings-note"
                   Text="连通测试会对 GetTask/Report 两个端点执行网络探测，失败会区分参数错误/网络失败/不支持。" />
      </StackPanel>
    </StackPanel>
  </Grid>
</UserControl>
