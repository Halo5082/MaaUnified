<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.AboutSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="About" />
    <WrapPanel Grid.Row="1" ItemWidth="200">
      <Button Content="官网" />
      <Button Content="社区" />
      <Button Content="检查公告" />
      <Button Content="下载页" />
    </WrapPanel>
    <TextBlock Grid.Row="2" Text="跨平台 Avalonia UI 复刻版，行为与 Windows 客户端保持一致优先。" />
  </Grid>
</UserControl>
