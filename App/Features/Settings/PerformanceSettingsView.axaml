<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.PerformanceSettingsView">
  <StackPanel Margin="4" Spacing="6">
    <TextBlock Classes="section-title" Text="Performance" />
    <WrapPanel ItemWidth="220">
      <CheckBox Content="启用 GPU 推理" />
      <CheckBox Content="过滤弃用项" />
      <CheckBox Content="启用低功耗模式" />
      <CheckBox Content="任务日志限流" />
    </WrapPanel>
  </StackPanel>
</UserControl>
