<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.ConfigurationManagerView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="4">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.ConfigurationManager]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.ConfigurationManager.ProfileName]}" />
      <ComboBox Width="{DynamicResource MAA.Size.Settings.ColumnWidth}"
                ItemsSource="{Binding ConfigurationProfiles}"
                SelectedValueBinding="{Binding .}"
                SelectedValue="{Binding ConfigurationManagerSelectedProfile}"
                SelectionChanged="OnConfigurationProfileSelectionChanged" />
    </StackPanel>

    <Grid Grid.Row="2"
          Width="{DynamicResource MAA.Size.Settings.ColumnWidth}"
          HorizontalAlignment="Center"
          ColumnDefinitions="*,Auto"
          Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <TextBox Text="{Binding ConfigurationManagerNewProfileName, UpdateSourceTrigger=LostFocus}"
               Watermark="{Binding RootTexts[Settings.ConfigurationManager.NewProfileWatermark]}" />
      <Button Grid.Column="1"
              Classes="wpf-button wpf-button-secondary"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              Content="{Binding RootTexts[Settings.ConfigurationManager.SaveAsNew]}"
              Click="OnCreateProfileClick" />
    </Grid>

    <Grid Grid.Row="3"
          HorizontalAlignment="Center"
          ColumnDefinitions="Auto,Auto"
          Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Button Classes="wpf-button wpf-button-secondary"
              Content="{Binding RootTexts[Settings.ConfigurationManager.DeleteCurrent]}"
              Click="OnDeleteCurrentProfileClick" />
      <TextBlock Grid.Column="1"
                 Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                 VerticalAlignment="Center"
                 Classes="state-success"
                 Text="{Binding RootTexts[Settings.ConfigurationManager.AutoSavedCurrent]}" />
    </Grid>

    <Grid Grid.Row="4"
          HorizontalAlignment="Center"
          ColumnDefinitions="Auto,Auto,Auto"
          Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Button Classes="wpf-button wpf-button-secondary"
              Content="{Binding RootTexts[Settings.ConfigurationManager.ExportAll]}"
              Click="OnExportAllProfilesClick" />
      <Button Grid.Column="1"
              Classes="wpf-button wpf-button-secondary"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              Content="{Binding RootTexts[Settings.ConfigurationManager.ExportCurrent]}"
              Click="OnExportCurrentProfileClick" />
      <Button Grid.Column="2"
              Classes="wpf-button wpf-button-secondary"
              Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
              Content="{Binding RootTexts[Settings.ConfigurationManager.Import]}"
              Click="OnImportProfilesClick" />
    </Grid>

    <StackPanel Grid.Row="5"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text" Text="{Binding ConfigurationManagerStatusMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding ConfigurationManagerErrorMessage}"
                 IsVisible="{Binding HasConfigurationManagerErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
