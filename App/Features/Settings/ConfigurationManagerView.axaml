<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.ConfigurationManagerView">
  <Grid RowDefinitions="Auto,Auto,Auto" Margin="4">
    <TextBlock Classes="section-title" Text="Configuration Manager" />
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
      <ComboBox>
        <ComboBoxItem Content="Default" />
      </ComboBox>
      <Button Grid.Column="1" Content="新增" />
      <Button Grid.Column="2" Content="删除" />
      <Button Grid.Column="3" Content="上移" />
      <Button Grid.Column="4" Content="下移" />
    </Grid>
    <TextBlock Grid.Row="2" Text="配置切换/新增/删除/排序将同步到 avalonia.json。" />
  </Grid>
</UserControl>
