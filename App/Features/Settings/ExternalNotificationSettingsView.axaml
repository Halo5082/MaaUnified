<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.ExternalNotificationSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="External Notification" />
    <WrapPanel Grid.Row="1" ItemWidth="220">
      <CheckBox Content="启用外部通知" />
      <CheckBox Content="任务完成发送" />
      <CheckBox Content="任务错误发送" />
      <CheckBox Content="超时发送" />
      <CheckBox Content="附带详细信息" />
    </WrapPanel>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,200,Auto,200,Auto,200">
      <TextBlock VerticalAlignment="Center" Text="SMTP" />
      <TextBox Watermark="smtp.example.com:465" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Telegram" />
      <TextBox Grid.Column="3" Watermark="bot-token/chat-id" />
      <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Webhook" />
      <TextBox Grid.Column="5" Watermark="https://..." />
    </Grid>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
      <Button Content="Provider 管理" />
      <Button Content="测试发送" />
    </StackPanel>
  </Grid>
</UserControl>
