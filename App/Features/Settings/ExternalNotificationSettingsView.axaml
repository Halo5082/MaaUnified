<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.ExternalNotificationSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.ExternalNotification]}" />
    <TextBlock Grid.Row="1"
               MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
               Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
               Classes="settings-centered-text"
               Text="{Binding RootTexts[Settings.ExternalNotification.OnlyCompleteNote]}" />

    <StackPanel Grid.Row="2"
                Classes="settings-form"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="{DynamicResource MAA.Spacing.Medium}">
      <CheckBox HorizontalAlignment="Center"
                Content="{Binding RootTexts[Settings.ExternalNotification.Enabled]}"
                IsChecked="{Binding ExternalNotificationEnabled}" />

      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,Auto"
            IsEnabled="{Binding CanEditExternalNotification}">
        <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                  ItemsSource="{Binding AvailableNotificationProviders}"
                  SelectedItem="{Binding SelectedNotificationProvider}" />
        <Button Grid.Column="1"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="{Binding RootTexts[Settings.ExternalNotification.TestSend]}"
                Click="OnTestSendClick" />
      </Grid>

      <StackPanel Classes="settings-centered-column"
                  Spacing="0"
                  IsEnabled="{Binding CanEditExternalNotification}">
        <CheckBox Content="{Binding RootTexts[Settings.ExternalNotification.SendWhenComplete]}"
                  IsChecked="{Binding ExternalNotificationSendWhenComplete}"
                  IsEnabled="{Binding CanEditExternalNotification}" />
        <CheckBox Margin="{DynamicResource MAA.Thickness.Settings.BranchIndent}"
                  Content="{Binding RootTexts[Settings.ExternalNotification.EnableDetails]}"
                  IsChecked="{Binding ExternalNotificationEnableDetails}"
                  IsEnabled="{Binding CanEditExternalNotificationDetails}"
                  IsVisible="{Binding ExternalNotificationSendWhenComplete}" />
        <CheckBox Content="{Binding RootTexts[Settings.ExternalNotification.SendWhenError]}"
                  IsChecked="{Binding ExternalNotificationSendWhenError}"
                  IsEnabled="{Binding CanEditExternalNotification}" />
        <CheckBox Content="{Binding RootTexts[Settings.ExternalNotification.SendWhenTimeout]}"
                  IsChecked="{Binding ExternalNotificationSendWhenTimeout}"
                  IsEnabled="{Binding CanEditExternalNotification}" />
      </StackPanel>

      <StackPanel Classes="settings-centered-column"
                  Spacing="{DynamicResource MAA.Spacing.Small}"
                  IsEnabled="{Binding CanEditExternalNotification}">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.ExternalNotification.ProviderParameters]}" />
        <TextBlock Classes="settings-note settings-centered-text"
                   Text="{Binding RootTexts[Settings.ExternalNotification.ProviderParametersNote]}" />
        <TextBox Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                 Height="150"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Text="{Binding NotificationProviderParametersText, UpdateSourceTrigger=LostFocus}" />
      </StackPanel>

      <StackPanel Classes="settings-centered-column"
                  Spacing="{DynamicResource MAA.Spacing.Small}"
                  IsEnabled="{Binding CanEditExternalNotification}">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.ExternalNotification.TestTitle]}" />
        <TextBox Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                 Text="{Binding NotificationTitle, UpdateSourceTrigger=LostFocus}" />
      </StackPanel>

      <StackPanel Classes="settings-centered-column"
                  Spacing="{DynamicResource MAA.Spacing.Small}"
                  IsEnabled="{Binding CanEditExternalNotification}">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.ExternalNotification.TestMessage]}" />
        <TextBox Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                 Text="{Binding NotificationMessage, UpdateSourceTrigger=LostFocus}" />
      </StackPanel>

      <Button Classes="wpf-button wpf-button-secondary"
              HorizontalAlignment="Center"
              Content="{Binding RootTexts[Settings.Action.ValidateNotification]}"
              Click="OnValidateProviderClick" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text"
                 Text="{Binding ExternalNotificationStatusMessage}"
                 IsVisible="{Binding HasExternalNotificationStatusMessage}" />
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding ExternalNotificationWarningMessage}"
                 IsVisible="{Binding HasExternalNotificationWarningMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding ExternalNotificationErrorMessage}"
                 IsVisible="{Binding HasExternalNotificationErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
