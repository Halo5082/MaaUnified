<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.TaskQueue.CustomSettingsView">
  <Grid RowDefinitions="Auto,Auto" Margin="2">
    <TextBlock Classes="section-title" Text="{Binding Texts[Custom.Title]}" />

    <StackPanel Grid.Row="1" Spacing="{DynamicResource MAA.Spacing.Small}">
      <TextBlock Text="{Binding Texts[Custom.TaskNames]}" />
      <TextBox AcceptsReturn="True" Height="120" Text="{Binding TaskNamesText, UpdateSourceTrigger=LostFocus}" />

      <TextBlock Text="{Binding Texts[Custom.TaskNamesPreview]}" />
      <TextBlock Text="{Binding TaskNamesPreview}" TextWrapping="Wrap" />

      <TextBlock Text="{Binding Texts[Common.LoadingTaskHint]}" />
      <TextBlock Text="{Binding StatusMessage}" />
      <TextBlock Foreground="{DynamicResource MAA.ErrorBrush}"
                 Text="{Binding LastErrorMessage}"
                 TextWrapping="Wrap" />

      <StackPanel IsVisible="{Binding HasValidationIssues}">
        <TextBlock Text="{Binding Texts[Common.ValidationIssues]}" />
        <ListBox MaxHeight="96" ItemsSource="{Binding ValidationMessages}" />
      </StackPanel>
    </StackPanel>
  </Grid>
</UserControl>
