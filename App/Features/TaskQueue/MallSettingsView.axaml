<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.TaskQueue.MallSettingsView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="2">
    <TextBlock Classes="section-title" Text="{Binding Texts[Mall.Title]}" />

    <WrapPanel Grid.Row="1" ItemWidth="230" Orientation="Horizontal">
      <CheckBox Content="{Binding Texts[Mall.VisitFriends]}" IsChecked="{Binding VisitFriends}" />
      <CheckBox Content="{Binding Texts[Mall.VisitOnce]}" IsChecked="{Binding VisitFriendsOnceADay}" />
      <CheckBox Content="{Binding Texts[Mall.CreditFight]}" IsChecked="{Binding CreditFight}" />
      <CheckBox Content="{Binding Texts[Mall.CreditFightOnce]}" IsChecked="{Binding CreditFightOnceADay}" />
      <CheckBox Content="{Binding Texts[Mall.Shopping]}" IsChecked="{Binding Shopping}" />
    </WrapPanel>

    <Grid Grid.Row="2" ColumnDefinitions="Auto,120,Auto,*">
      <TextBlock VerticalAlignment="Center" Text="{Binding Texts[Mall.Formation]}" />
      <NumericUpDown Grid.Column="1" Minimum="0" Maximum="4" Value="{Binding FormationIndex}" />
      <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Texts[Mall.BuyFirst]}" />
      <TextBox Grid.Column="3" Text="{Binding BuyFirstText}" />
    </Grid>

    <Grid Grid.Row="3" ColumnDefinitions="Auto,*">
      <TextBlock VerticalAlignment="Center" Text="{Binding Texts[Mall.Blacklist]}" />
      <TextBox Text="{Binding BlacklistText}" />
    </Grid>

    <WrapPanel Grid.Row="4" ItemWidth="230" Orientation="Horizontal">
      <CheckBox Content="{Binding Texts[Mall.ForceShopping]}" IsChecked="{Binding ForceShoppingIfCreditFull}" />
      <CheckBox Content="{Binding Texts[Mall.OnlyDiscount]}" IsChecked="{Binding OnlyBuyDiscount}" />
      <CheckBox Content="{Binding Texts[Mall.Reserve]}" IsChecked="{Binding ReserveMaxCredit}" />
    </WrapPanel>
  </Grid>
</UserControl>
