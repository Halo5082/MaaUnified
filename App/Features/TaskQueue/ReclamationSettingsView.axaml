<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.ReclamationSettingsView">
  <Grid RowDefinitions="Auto,Auto" Margin="2">
    <TextBlock Classes="section-title" Text="{Binding Texts[Reclamation.Title]}" />

    <StackPanel Grid.Row="1" Spacing="{DynamicResource MAA.Spacing.Small}">
      <StackPanel IsVisible="{Binding IsGeneralMode}" Spacing="{DynamicResource MAA.Spacing.Small}">
        <TextBlock Text="{Binding Texts[Reclamation.Theme]}" />
        <ComboBox ItemsSource="{Binding ThemeOptions}"
                  SelectedValueBinding="{Binding Type}"
                  SelectedValue="{Binding Theme}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:TaskModuleOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="{Binding Texts[Reclamation.Mode]}" />
        <ComboBox ItemsSource="{Binding ModeOptions}"
                  SelectedValueBinding="{Binding Value}"
                  SelectedValue="{Binding Mode}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ReclamationModuleViewModel+IntOption">
              <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Classes="subtle"
                   Margin="{DynamicResource MAA.Thickness.MarginTopSmall}"
                   Text="{Binding Texts[Reclamation.EarlyTip]}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel IsVisible="{Binding IsAdvancedMode}" Spacing="{DynamicResource MAA.Spacing.Small}">
        <TextBlock Text="{Binding Texts[Reclamation.ToolToCraftTip]}" />
        <TextBox Watermark="{Binding Texts[Reclamation.ToolToCraftPlaceholder]}"
                 IsEnabled="{Binding IsArchiveSettingsEnabled}"
                 Text="{Binding ToolsToCraftText, UpdateSourceTrigger=LostFocus}" />

        <TextBlock Text="{Binding Texts[Reclamation.IncrementMode]}" />
        <ComboBox IsEnabled="{Binding IsArchiveSettingsEnabled}"
                  ItemsSource="{Binding IncrementModeOptions}"
                  SelectedValueBinding="{Binding Value}"
                  SelectedValue="{Binding IncrementMode}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ReclamationModuleViewModel+IntOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="{Binding Texts[Reclamation.NumCraftBatches]}" />
        <controls:VerticalSpinNumberBox Minimum="0"
                                        Maximum="99999"
                                        IsEnabled="{Binding IsArchiveSettingsEnabled}"
                                        Value="{Binding NumCraftBatches}" />

        <CheckBox Content="{Binding Texts[Reclamation.ClearStore]}"
                  IsChecked="{Binding ClearStore}"
                  IsVisible="{Binding ShowClearStore}" />
      </StackPanel>

      <TextBlock Text="{Binding Texts[Common.LoadingTaskHint]}" />
      <TextBlock Text="{Binding StatusMessage}" />
      <TextBlock Foreground="{DynamicResource MAA.ErrorBrush}"
                 Text="{Binding LastErrorMessage}"
                 TextWrapping="Wrap" />
      <StackPanel IsVisible="{Binding HasValidationIssues}">
        <TextBlock Text="{Binding Texts[Common.ValidationIssues]}" />
        <ListBox MaxHeight="96" ItemsSource="{Binding ValidationMessages}" />
      </StackPanel>
    </StackPanel>
  </Grid>
</UserControl>
