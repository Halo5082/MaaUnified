<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.InfrastSettingsView">
  <Grid RowDefinitions="Auto,Auto" Margin="2">
    <TextBlock Classes="section-title" Text="{Binding Texts[Infrast.Title]}" />

    <StackPanel Grid.Row="1" Spacing="{DynamicResource MAA.Spacing.Small}">
      <StackPanel IsVisible="{Binding IsGeneralMode}" Spacing="{DynamicResource MAA.Spacing.Small}">
        <Grid ColumnDefinitions="Auto,Auto">
          <TextBlock Text="{Binding Texts[Infrast.Mode]}" />
          <controls:TooltipHint Grid.Column="1"
                                IsVisible="{Binding ShowRotationTip}"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                Tip="{Binding Texts[Infrast.ModeRotationToolTip]}" />
        </Grid>
        <ComboBox ItemsSource="{Binding ModeOptions}"
                  SelectedValueBinding="{Binding Value}"
                  SelectedValue="{Binding Mode}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:InfrastModuleViewModel+IntOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <StackPanel IsVisible="{Binding ShowCustomModeSettings}" Spacing="{DynamicResource MAA.Spacing.Small}">
          <Grid ColumnDefinitions="Auto,Auto">
            <TextBlock Text="{Binding Texts[Infrast.Plan]}" />
            <controls:TooltipHint Grid.Column="1"
                                  Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                  Tip="{Binding Texts[Infrast.CustomPlanToolTip]}" />
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding PlanOptions}"
                      SelectedValueBinding="{Binding Index}"
                      SelectedValue="{Binding SelectedPlanIndex}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:InfrastModuleViewModel+PlanOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1"
                    Classes="wpf-button wpf-button-secondary"
                    Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                    Content="{Binding Texts[Infrast.Plan.Refresh]}"
                    Click="OnReloadPlansClick" />
          </Grid>

          <TextBlock Text="{Binding Texts[Infrast.DefaultPreset]}" />
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding DefaultInfrastOptions}"
                      SelectedValueBinding="{Binding Value}"
                      SelectedValue="{Binding DefaultInfrast}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:InfrastModuleViewModel+StringOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1"
                    Classes="wpf-button wpf-button-secondary"
                    Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                    Content="{Binding Texts[Infrast.Select]}"
                    Click="OnSelectCustomFileClick" />
          </Grid>

          <TextBlock Text="{Binding Texts[Infrast.File]}" />
          <TextBox IsReadOnly="{Binding IsCustomFileReadOnly}"
                   Text="{Binding CustomFilePath, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <TextBlock IsVisible="{Binding ShowRotationTip}"
                   Text="{Binding Texts[Infrast.ModeRotationTip]}"
                   TextWrapping="Wrap" />

        <TextBlock Text="{Binding Texts[Infrast.Drones]}" />
        <ComboBox ItemsSource="{Binding DroneOptions}"
                  IsEnabled="{Binding CanEditDrones}"
                  SelectedValueBinding="{Binding Value}"
                  SelectedValue="{Binding Drones}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:InfrastModuleViewModel+StringOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <StackPanel IsVisible="{Binding ShowThresholdSettings}" Spacing="{DynamicResource MAA.Spacing.Small}">
          <Grid ColumnDefinitions="Auto,Auto">
            <TextBlock Text="{Binding Texts[Infrast.Threshold]}" />
            <controls:TooltipHint Grid.Column="1"
                                  Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                  Tip="{Binding Texts[Infrast.ThresholdTip]}" />
          </Grid>
          <Slider Minimum="0" Maximum="100" Value="{Binding DormThresholdPercent}" />
          <TextBlock Classes="subtle" Text="{Binding DormThresholdPercent, StringFormat='{}{0}%'}" />
        </StackPanel>

        <TextBlock Text="{Binding Texts[Infrast.Facility]}" />
        <ListBox Classes="wpf-list-no-highlight"
                 ItemsSource="{Binding FacilityOptions}"
                 MaxHeight="196">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:InfrastModuleViewModel+FacilityOption">
              <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Grid ColumnDefinitions="*,*">
          <Button Classes="wpf-button wpf-button-secondary"
                  Content="{Binding Texts[Infrast.SelectAll]}"
                  Click="OnSelectAllFacilityClick" />
          <Button Grid.Column="1"
                  Classes="wpf-button wpf-button-secondary"
                  Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                  Content="{Binding Texts[Infrast.Clear]}"
                  Click="OnClearFacilityClick" />
        </Grid>
      </StackPanel>

      <StackPanel IsVisible="{Binding IsAdvancedMode}" Spacing="{DynamicResource MAA.Spacing.Small}">
        <CheckBox Content="{Binding Texts[Infrast.Trust]}"
                  IsChecked="{Binding DormTrustEnabled}"
                  IsVisible="{Binding ShowDormFilterSettings}" />
        <Grid ColumnDefinitions="Auto,Auto" IsVisible="{Binding ShowDormFilterSettings}">
          <CheckBox Content="{Binding Texts[Infrast.NotStationed]}" IsChecked="{Binding DormNotStationedEnabled}" />
          <controls:TooltipHint Grid.Column="1"
                                Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                Tip="{Binding Texts[Infrast.NotStationedTip]}" />
        </Grid>
        <CheckBox Content="{Binding Texts[Infrast.Replenish]}" IsChecked="{Binding Replenish}" />
        <CheckBox Content="{Binding Texts[Infrast.ReceptionBoard]}" IsChecked="{Binding ReceptionMessageBoard}" />
        <CheckBox Content="{Binding Texts[Infrast.ReceptionExchange]}" IsChecked="{Binding ReceptionClueExchange}" />
        <CheckBox Content="{Binding Texts[Infrast.ReceptionSend]}" IsChecked="{Binding ReceptionSendClue}" />
        <CheckBox Content="{Binding Texts[Infrast.ContinueTraining]}" IsChecked="{Binding ContinueTraining}" />
      </StackPanel>

      <TextBlock Foreground="{DynamicResource MAA.WarningBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      <TextBlock Foreground="{DynamicResource MAA.ErrorBrush}" Text="{Binding LastErrorMessage}" TextWrapping="Wrap" />
    </StackPanel>
  </Grid>
</UserControl>
