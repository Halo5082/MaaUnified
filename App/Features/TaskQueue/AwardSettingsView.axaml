<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.TaskQueue.AwardSettingsView">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="2">
    <TextBlock Classes="section-title" Text="{Binding Texts[Award.Title]}" />

    <WrapPanel Grid.Row="1" ItemWidth="220" Orientation="Horizontal">
      <CheckBox Content="{Binding Texts[Award.Award]}" IsChecked="{Binding Award}" />
      <CheckBox Content="{Binding Texts[Award.Mail]}" IsChecked="{Binding Mail}" />
      <CheckBox Content="{Binding Texts[Award.Recruit]}" IsChecked="{Binding Recruit}" />
      <CheckBox Content="{Binding Texts[Award.Orundum]}" IsChecked="{Binding Orundum}" />
      <CheckBox Content="{Binding Texts[Award.Mining]}" IsChecked="{Binding Mining}" />
      <CheckBox Content="{Binding Texts[Award.Special]}" IsChecked="{Binding SpecialAccess}" />
    </WrapPanel>

    <Border Grid.Row="2"
            Padding="8"
            Margin="0,8,0,0"
            CornerRadius="6"
            BorderThickness="1"
            BorderBrush="{DynamicResource MAA.WarningBrush}"
            IsVisible="{Binding PendingRecruitConfirmation}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock VerticalAlignment="Center" Text="{Binding Texts[Award.RecruitTip]}" />
        <Button Content="{Binding Texts[Award.Confirm]}" Click="OnConfirmRecruitClick" />
        <Button Content="{Binding Texts[Award.Cancel]}" Click="OnCancelRecruitClick" />
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="3" Foreground="{DynamicResource MAA.WarningBrush}" Text="{Binding StatusMessage}" />
  </Grid>
</UserControl>
