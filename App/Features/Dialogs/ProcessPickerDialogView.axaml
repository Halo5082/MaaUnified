<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.ProcessPickerDialogView">
  <Grid Margin="8" RowDefinitions="Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Process Picker" />
    <ListBox Grid.Row="1">
      <ListBoxItem Content="MAA Emulator - pid: 1234" />
      <ListBoxItem Content="MuMu Player - pid: 5678" />
      <ListBoxItem Content="LDPlayer - pid: 9012" />
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="刷新" />
      <Button Content="取消" />
      <Button Content="选择" />
    </StackPanel>
  </Grid>
</UserControl>
