<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.ProcessPickerDialogView"
        Width="620"
        Height="460"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Process Picker" />
    <ListBox x:Name="ProcessList"
             Grid.Row="1"
             Margin="0,8,0,0"
             SelectionMode="Single">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Classes="long-wrap" Text="{Binding DisplayName}" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Refresh" Click="OnRefreshClick" />
      <Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="action" Content="Select" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
