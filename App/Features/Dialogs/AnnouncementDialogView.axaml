<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.AnnouncementDialogView">
  <Grid Margin="8" RowDefinitions="Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Announcement" />
    <ScrollViewer Grid.Row="1">
      <TextBlock TextWrapping="Wrap"
                 Text="公告内容支持 Markdown 渲染（标题、链接、代码块）。" />
    </ScrollViewer>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="忽略" />
      <Button Content="查看详情" />
    </StackPanel>
  </Grid>
</UserControl>
