<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.TextDialogView">
  <Grid Margin="8" RowDefinitions="Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Text Dialog" />
    <TextBox Grid.Row="1"
             AcceptsReturn="True"
             Height="160"
             TextWrapping="Wrap"
             Text="支持 Markdown 预览或纯文本显示。" />
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="取消" />
      <Button Content="确认" />
    </StackPanel>
  </Grid>
</UserControl>
