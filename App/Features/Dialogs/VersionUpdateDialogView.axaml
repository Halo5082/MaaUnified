<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.VersionUpdateDialogView">
  <Grid Margin="8" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Version Update" />
    <TextBlock Grid.Row="1" Text="发现新版本: v5.0.0 -> v5.1.0" />
    <ScrollViewer Grid.Row="2">
      <TextBlock TextWrapping="Wrap" Text="- 更新内容支持 Markdown 展示&#10;- 支持手动/自动更新&#10;- 支持资源包更新" />
    </ScrollViewer>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="稍后" />
      <Button Content="下载更新" />
      <Button Content="立即更新" />
    </StackPanel>
  </Grid>
</UserControl>
