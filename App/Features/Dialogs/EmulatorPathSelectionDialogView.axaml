<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.EmulatorPathSelectionDialogView">
  <Grid Margin="8" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="Emulator Path Selection" />
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
      <TextBox Watermark="/path/to/emulator" />
      <Button Grid.Column="1" Content="浏览" />
    </Grid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="取消" />
      <Button Content="确认" />
    </StackPanel>
  </Grid>
</UserControl>
