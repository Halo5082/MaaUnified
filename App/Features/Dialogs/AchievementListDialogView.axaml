<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.AchievementListDialogView"
        Width="760"
        Height="520"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock x:Name="DialogTitleText"
               Classes="section-title"
               Text="Achievement List" />
    <TextBox x:Name="FilterInput"
             Grid.Row="1"
             Margin="0,8,0,0"
             Watermark="Filter"
             TextChanged="OnFilterChanged" />
    <ListBox x:Name="AchievementList"
             Grid.Row="2"
             Margin="0,8,0,0"
             SelectionMode="Multiple">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8"
                  Padding="10"
                  CornerRadius="10"
                  Background="#14000000"
                  BorderBrush="#22000000"
                  BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*">
              <Border Width="42"
                      Height="42"
                      Margin="0,4,10,0"
                      CornerRadius="21"
                      Background="{Binding MedalColor}"
                      VerticalAlignment="Top" />
              <StackPanel Grid.Column="1" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Text="{Binding NewBadgeText}"
                             FontWeight="Bold"
                             Foreground="#D96C0D"
                             IsVisible="{Binding IsNewUnlock}" />
                </StackPanel>
                <TextBlock Classes="long-wrap" Opacity="0.9" Text="{Binding Description}" />
                <TextBlock Classes="long-wrap subtle" Text="{Binding Conditions}" />
                <ProgressBar Minimum="0"
                             Maximum="{Binding Target}"
                             Value="{Binding Progress}"
                             IsVisible="{Binding ShowProgress}"
                             Height="10"
                             Width="220" />
                <TextBlock Text="{Binding ProgressText}"
                           IsVisible="{Binding ShowProgress}" />
                <TextBlock Opacity="0.72" Text="{Binding Status}" />
                <TextBlock Text="{Binding UnlockedAtText}"
                           Foreground="{Binding MedalColor}"
                           IsVisible="{Binding IsUnlocked}" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Classes="wpf-button wpf-button-secondary" x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="wpf-button" Content="Confirm" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
