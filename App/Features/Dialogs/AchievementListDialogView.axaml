<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.AchievementListDialogView">
  <Grid Margin="8" RowDefinitions="Auto,*,Auto">
    <TextBlock Classes="section-title" Text="Achievement List" />
    <ListBox Grid.Row="1">
      <ListBoxItem Content="任务达人 - 已完成" />
      <ListBoxItem Content="连续签到王 - 已完成" />
      <ListBoxItem Content="资源收集者 - 进行中" />
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="导出" />
      <Button Content="关闭" />
    </StackPanel>
  </Grid>
</UserControl>
