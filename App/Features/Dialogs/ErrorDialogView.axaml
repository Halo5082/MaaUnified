<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Dialogs.ErrorDialogView">
  <Grid Margin="8" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Classes="section-title" Foreground="{DynamicResource MAA.ErrorBrush}" Text="Error" />
    <TextBlock Grid.Row="1" Text="发生错误，详情如下：" />
    <TextBox Grid.Row="2"
             AcceptsReturn="True"
             IsReadOnly="True"
             Text="ErrorCode: ...&#10;Message: ...&#10;Details: ..."
             Height="140" />
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="复制错误" />
      <Button Content="打开 IssueReport" />
      <Button Content="关闭" />
    </StackPanel>
  </Grid>
</UserControl>
