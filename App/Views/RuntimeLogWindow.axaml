<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Views.RuntimeLogWindow"
        Width="920"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        Title="Runtime Logs">
  <Grid Margin="{DynamicResource MAA.Thickness.PageMargin}" RowDefinitions="*,*">
    <Border Classes="wpf-panel wpf-panel-strong">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Classes="section-title" Text="{Binding RootTexts[Main.Sidebar.GrowlAndCapability]}" />
        <TextBlock Grid.Row="1"
                   Classes="long-wrap subtle"
                   Text="{Binding CapabilitySummary}" />
        <ListBox Grid.Row="2"
                 Margin="{DynamicResource MAA.Thickness.MarginTopList}"
                 ItemsSource="{Binding GrowlMessages}" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="wpf-panel wpf-panel-strong"
            Margin="{DynamicResource MAA.Thickness.MarginTopSection}">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Classes="section-title" Text="{Binding RootTexts[Main.Footer.RootLogs]}" />
        <ListBox Grid.Row="1"
                 Margin="{DynamicResource MAA.Thickness.MarginTopList}"
                 ItemsSource="{Binding RootLogs}" />
      </Grid>
    </Border>
  </Grid>
</Window>
